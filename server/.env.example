# Токен Telegram-бота (от @BotFather)
TELEGRAM_TOKEN=

# Ключ Anthropic API для AI-коуча
ANTHROPIC_API_KEY=

# Секрет для подписи JWT (вход через сайт). Сгенерировать: openssl rand -hex 32
# Если не задан — используется TELEGRAM_TOKEN (работает, но не рекомендуется для прода)
JWT_SECRET=

# Путь к файлу SQLite. На Railway должен указывать на смонтированный volume,
# иначе БД сотрётся при следующем деплое.
DB_PATH=/app/data/checkins.db

# Порт API-сервера (Railway подставляет свой автоматически)
PORT=3001

# Dev-вход без Telegram Login Widget (виджет не работает на localhost).
# Держать выключенным (0 или не задавать) в проде.
DEV_LOGIN=0

# URL фронтенда — на него бот шлёт одноразовую ссылку для входа (/login)
FRONTEND_URL=https://life-os-tau-sand.vercel.app
